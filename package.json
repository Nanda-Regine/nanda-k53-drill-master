{
  "name": "k53-learners-prep",
  "private": true,
  "version": "1.0.0",
  "description": "Free South African K53 learner's licence drill app",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "validate": "node scripts/validate-questions.mjs",
    "test": "node scripts/validate-questions.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "build:app": "vite build --mode capacitor",
    "cap:sync": "npm run build:app && cap sync",
    "cap:android": "npm run cap:sync && cap open android"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.4.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@supabase/supabase-js": "^2.98.0",
    "@vercel/analytics": "^1.6.1",
    "framer-motion": "^12.35.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "pdf-parse": "^2.4.5",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^0.21.0"
  }
}
