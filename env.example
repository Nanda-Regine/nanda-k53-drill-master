# K53 Drill Master — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git (it's already in .gitignore)
# Vite rule: browser-visible vars MUST start with VITE_
#            server-only vars (API routes) use no prefix


# ── Supabase ──────────────────────────────────────────────────────────────────
# Find these in Supabase → Settings → API
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Server-only (Vercel serverless functions — NEVER expose to browser)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...


# ── AI Keys ───────────────────────────────────────────────────────────────────
# OpenAI — used by AI Tutor (Explain This button in-app)
VITE_OPENAI_API_KEY=sk-proj-...

# Anthropic — reserved for server-side AI features
ANTHROPIC_API_KEY=sk-ant-api03-...


# ── Payments (PayFast) ────────────────────────────────────────────────────────
# Server-only — never expose merchant key/passphrase to browser
PAYFAST_MERCHANT_ID=17030173
PAYFAST_MERCHANT_KEY=...
PAYFAST_PASSPHRASE=...
PAYFAST_SANDBOX=false


# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...


# ── Error Monitoring (Sentry) ────────────────────────────────────────────────
# DSN is safe to expose (it's public by design)
VITE_SENTRY_DSN=https://xxxx@oxxxx.ingest.de.sentry.io/xxxx
# Server-side auth token for source map uploads (keep secret)
SENTRY_AUTH_TOKEN=...


# ── Analytics (PostHog) ───────────────────────────────────────────────────────
# Token is safe to expose (browser-side analytics)
VITE_POSTHOG_TOKEN=phc_...
VITE_POSTHOG_HOST=https://us.i.posthog.com


# ── Analytics (Google) ────────────────────────────────────────────────────────
# GTM container ID — hardcoded in index.html, no env var needed
# GOOGLE_TAG=GTM-KF2HMVLN

# GA4 Measurement ID (used if you add gtag.js separately)
VITE_GA_MEASUREMENT_ID=G-...

# Google Search Console verification — hardcoded in index.html meta tag


# ── Live Chat (Crisp) ─────────────────────────────────────────────────────────
VITE_CRISP_WEBSITE_ID=...


# ── Security (Arcjet) ────────────────────────────────────────────────────────
# Server-only — bot protection / rate limiting in API routes
ARCJET_KEY=ajkey_...


# ── Site ─────────────────────────────────────────────────────────────────────
SITE_URL=https://k53drillmaster.co.za
